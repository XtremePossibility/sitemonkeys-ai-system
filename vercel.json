{
  "functions": {
    "api/functions/**/*.js": {
      "runtime": "nodejs18.x"
    },
    "api/functions/**/*.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/functions/chat"
    },
    {
      "source": "/api/code-generation", 
      "destination": "/api/functions/code-generation"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/functions/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
