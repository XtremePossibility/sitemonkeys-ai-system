{
  "functions": {
    "api/functions/**/*.js": {
      "runtime": "nodejs"
    },
    "api/functions/**/*.py": {
      "runtime": "python"
    }
  },
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/functions/chat"
    },
    {
      "source": "/api/code-generation", 
      "destination": "/api/functions/code-generation"
    },
    {
      "source": "/api/migrate-vault-run",
      "destination": "/api/functions/migrate-vault-run"
    },
    {
      "source": "/api/migrate-vault",
      "destination": "/api/functions/migrate-vault"
    },
    {
      "source": "/api/upload-file",
      "destination": "/api/functions/upload-file"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/functions/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
