{
  "version": 2,
  "functions": {
    "api/functions/**/*.js": {
      "runtime": "nodejs"
    },
    "api/functions/**/*.py": {
      "runtime": "python"
    }
  },
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/functions/chat/index.js"
    },
    {
      "src": "/api/code-generation", 
      "dest": "/api/functions/code-generation/index.js"
    },
    {
      "src": "/api/load-vault",
      "dest": "/api/functions/load-vault/index.py"
    },
    {
      "src": "/api/migrate-vault-run",
      "dest": "/api/functions/migrate-vault-run/index.py"
    },
    {
      "src": "/api/migrate-vault",
      "dest": "/api/functions/migrate-vault/index.py"
    },
    {
      "src": "/api/upload-file",
      "dest": "/api/functions/upload-file/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/functions/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "regions": ["iad1"],
  "cleanUrls": true,
  "trailingSlash": false
}
